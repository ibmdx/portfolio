    "cheragh.html": {
      "settings": {
        "meta_descr": "Cheragh is a startup at early stages that connects candidates who are looking for a job with the opportunities that suit them best. It also offers a wide variety of educational contents and personality tests.\n",
        "title": "CHERAGH  —  BMDX",
        "order": 4,
        "meta_image": "@PROJECT_PATH@/assets/images/cheragh.jpg"
      },
      "components": [
        {
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 15px)",
              "padding-bottom": "(@paddingBottom * 15px)"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "H1": {
              "text-align": "left",
              "color": "#ffffff"
            },
