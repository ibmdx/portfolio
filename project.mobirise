          "_sourceTheme": "mobirise4",
          "_cid": "r5l6OA0dtG",
          "_protectedParams": [],
          "_global": true,
          "_once": true,
          "_params": {}
        }
      ]
    },
    "gajino.html": {
      "settings": {
        "meta_descr": "Gajino is a mobile application for one of the biggest educational publications in MENA (Gaj international publications).\nThe persona of this service are students (kids and teenagers).",
        "title": "GAJINO  —  BMDX",
        "order": 2,
