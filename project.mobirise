          "_name": "header9",
          "_customHTML": "<section class=\"header9\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n    <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"9\" step=\"1\" value=\"9\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"9\" step=\"1\" value=\"5\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Show Arrow\" name=\"showArrow\">\n\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\">\n        <input type=\"checkbox\" title=\"Show Subtitle\" name=\"showSubTitle\">\n        <input type=\"checkbox\" title=\"Show Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Show Buttons\" name=\"showButtons\">\n\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value=\"@PROJECT_PATH@/assets/images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Background Color\" value=\"#100119\" selected>\n            <input type=\"video\" title=\"Background Video\" value=\"http://www.youtube.com/watch?v=uNCr7NdOJgw\">\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.2\" condition=\"overlay && bg.type !== 'color'\">\n    <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container\">\n        <div class=\"media-container-column mbr-white col-md-8\">\n            <h1 class=\"mbr-section-title align-left mbr-bold pb-3 mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><span style=\"font-weight: normal;\">—\n</span><div><span style=\"font-weight: normal;\">WHO I AM?</span></div></h1>\n            <h3 class=\"mbr-section-subtitle align-left mbr-light pb-3 mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showSubTitle\"><div><span style=\"font-style: normal; font-size: 1.2rem;\">I'm not just a designer!</span></div></h3>\n            <p class=\"mbr-text align-left pb-3 mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\"><b>—<br>W E B S I T E</b><b><br></b><br>Direction, Design, Development, Branding, Stracture, Strategy, SEO and Content:<br><a href=\"https://linkedin.com/in/bahramidesign\" target=\"_blank\">Mobin Bahrami</a><br><br>Photography:<br><a href=\"https://www.instagram.com/sbr.photography/\" target=\"_blank\">Behnam Saberi</a><br>\n<br>Logomotion:<br><a href=\"https://instagram.com/mbphpu\" target=\"_blank\">Mohammad Reza Bagheri (mbphpu)</a><br><br>Technologies:<br><a href=\"https://www.w3.org/html/\" target=\"_blank\">HTML</a>\n<br><a href=\"https://en.wikipedia.org/wiki/Cascading_Style_Sheets\" target=\"_blank\">CSS</a><br><a href=\"https://getbootstrap.com/\" target=\"_blank\">Bootstrap</a><a href=\"https://getbootstrap.com/\" target=\"_blank\"><br></a><a href=\"https://mobirise.com/\" target=\"_blank\">Mobirise</a><br><br>Fonts:<br><a href=\"https://fonts.google.com/specimen/Raleway\" target=\"_blank\">Raleway</a><br><a href=\"https://fonts.google.com/specimen/Exo+2\" target=\"_blank\">Exo2</a><br><a href=\"https://fonts.google.com/specimen/Open+Sans\" target=\"_blank\">Open Sans</a><br><br><br><br><br><b>—<br></b>\n<b>A B O U T</b><br><br><b><br></b>Mostafa Naghipourfar Profile Picture:<br><a href=\"https://way2pay.ir/\" target=\"_blank\">Way2Pay</a> - Silicon Iran (Iranian Enterpreneurs Froum)<br><br>Videos:<br><a href=\"https://www.aparat.com/itcafe/\" target=\"_blank\">Cafe IT</a> - TrigUp Workshops<br><a href=\"https://way2pay.ir/\" target=\"_blank\">Way2Pay</a>&nbsp;- Fintech Startupic Event<br><br><br><br><br><b>—<br>W O R K S</b><br><br><br><b>BDING:</b><br>\nIndustrial Designer:\n<a href=\"https://www.linkedin.com/in/miladtaleghani88\" target=\"_blank\">Milad Taleghani</a> (quality bonding)<br>Stand Mockup:&nbsp;<br><br><b>Kipaad:</b><br>\nCover Mockup:&nbsp;<a href=\"http://free-psd-templates.com\" target=\"_blank\">Free psd templates</a><br><br><b>Deco:</b><br>Background Cover Photo:&nbsp;Mohammad Norouzi<br><br><b>VigRX:</b><br>\nBackground Cover:&nbsp;<a href=\"http://www.freepik.com\" target=\"_blank\" class=\"text-primary\">kjpargeter</a><br>\n<br><b>Arghavan:</b><br>\nCover Mockup: <a href=\"http://www.freepik.com\" target=\"_blank\">Yanalya  / Freepik</a><br><b><br></b><b>MyMy! :</b><br>Cover Mockup:<b>&nbsp;</b><a href=\"http://www.freepik.com\" target=\"_blank\">Zlatko_Plamenov / Freepik</a><br><br>\n<br>\n<br></p>\n            <div class=\"mbr-section-btn align-left\" mbr-if=\"showButtons\" mbr-buttons mbr-theme-style=\"display-5\"><a class=\"btn btn-md btn-white-outline\" href=\"https://jobinja.ir/user/BahramiDesign\" data-app-placeholder=\"Type Text\" target=\"_blank\"><span class=\"mbrib-file mbr-iconfont mbr-iconfont-btn\" style=\"font-size: 25px; color: rgb(193, 193, 193);\"></span>My Resume</a></div>\n        </div>\n    </div>\n\n    <div mbr-if=\"showArrow\" class=\"mbr-arrow hidden-sm-down\" aria-hidden=\"true\">\n        <a href=\"#next\">\n            <i class=\"mbri-down mbr-iconfont\"></i>\n        </a>\n    </div>\n</section>",
          "_anchor": "header9-fo",
          "_isUserblock": true,
          "_sourceTheme": "mobirise4",
